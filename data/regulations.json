    {
      "id": "AU-OSA-2024",
      "name": "Online Safety Amendment (Social Media Minimum Age) Act 2024",
      "jurisdiction_id": "AU",
      "summary": "Australia's landmark legislation banning children under 16 from using social media platforms. Platforms must take reasonable steps to prevent underage users from holding accounts. Non-compliance penalties up to AUD 50 million.",
      "status": "passed",
      "service_type_ids": ["social_media"],
      "year": 2024,
      "source_url": "https://www.legislation.gov.au/C2024A00157/asmade",
      "tags": ["social_media_ban", "minimum_age_16", "platform_obligation"],
      "obligations": [
        {
          "id": "AU-OSA-2024-OBL-1",
          "regulation_id": "AU-OSA-2024",
          "type": "age_verification",
          "description": "Platforms must take reasonable steps to prevent children under 16 from holding accounts",
          "threshold_age": 16,
          "applies_to_service_types": ["social_media"]
        },
        {
          "id": "AU-OSA-2024-OBL-2",
          "regulation_id": "AU-OSA-2024",
          "type": "access_restriction",
          "description": "End-to-end age assurance systems required before account creation",
          "threshold_age": 16,
          "applies_to_service_types": ["social_media"]
        },
        {
          "id": "AU-OSA-2024-OBL-3",
          "regulation_id": "AU-OSA-2024",
          "type": "reporting_obligation",
          "description": "Platforms must report on age assurance compliance measures annually",
          "threshold_age": null,
          "applies_to_service_types": ["social_media"]
        }
      ],
      "milestones": [
        { "id": "AU-OSA-2024-MS-1", "regulation_id": "AU-OSA-2024", "type": "introduced", "date": "2024-09-09", "description": "Bill introduced to Parliament as Online Safety Amendment Bill", "source_url": null },
        { "id": "AU-OSA-2024-MS-2", "regulation_id": "AU-OSA-2024", "type": "committee_review", "date": "2024-11-18", "description": "Senate Environment and Communications References Committee report", "source_url": null },
        { "id": "AU-OSA-2024-MS-3", "regulation_id": "AU-OSA-2024", "type": "passed", "date": "2024-11-29", "description": "Passed both houses of Parliament with bipartisan support", "source_url": null },
