    {
      "id": "EU-DSA-2022",
      "name": "Digital Services Act (DSA) — Age Assurance Provisions",
      "jurisdiction_id": "EU",
      "summary": "EU regulation requiring online platforms to protect minors. Platforms must put in place appropriate age verification and parental consent mechanisms. Very Large Online Platforms (VLOPs) face additional obligations.",
      "status": "enforced",
      "service_type_ids": ["social_media", "online_marketplace", "streaming", "app_store"],
      "year": 2022,
      "source_url": "https://eur-lex.europa.eu/eli/reg/2022/2065/oj",
      "tags": ["dsa", "child_protection", "age_verification", "vlop"],
      "obligations": [
        {
          "id": "EU-DSA-2022-OBL-1",
          "regulation_id": "EU-DSA-2022",
          "type": "age_verification",
          "description": "Platforms must verify age for services that may pose risks to minors",
          "threshold_age": 18,
          "applies_to_service_types": ["social_media", "streaming"]
        },
        {
          "id": "EU-DSA-2022-OBL-2",
          "regulation_id": "EU-DSA-2022",
          "type": "parental_consent",
          "description": "Parental consent required for minors to use certain platform features",
          "threshold_age": 16,
          "applies_to_service_types": ["social_media", "online_marketplace"]
        },
        {
          "id": "EU-DSA-2022-OBL-3",
          "regulation_id": "EU-DSA-2022",
          "type": "design_restrictions",
          "description": "VLOPs must design systems to ensure high level of privacy, safety and security for minors",
          "threshold_age": null,
          "applies_to_service_types": ["social_media"]
        },
        {
          "id": "EU-DSA-2022-OBL-4",
          "regulation_id": "EU-DSA-2022",
          "type": "reporting_obligation",
          "description": "Platforms must report on measures taken to protect minors in annual transparency reports",
          "threshold_age": null,
          "applies_to_service_types": ["social_media", "online_marketplace", "streaming", "app_store"]
        }
      ],
      "milestones": [
        { "id": "EU-DSA-2022-MS-1", "regulation_id": "EU-DSA-2022", "type": "proposed", "date": "2020-12-15", "description": "European Commission proposed the DSA", "source_url": null },
        { "id": "EU-DSA-2022-MS-2", "regulation_id": "EU-DSA-2022", "type": "passed", "date": "2022-10-19", "description": "Adopted by EU legislature", "source_url": null },
        { "id": "EU-DSA-2022-MS-3", "regulation_id": "EU-DSA-2022", "type": "effective", "date": "2023-02-17", "description": "DSA entered into force", "source_url": null },
        { "id": "EU-DSA-2022-MS-4", "regulation_id": "EU-DSA-2022", "type": "enforced", "date": "2024-02-17", "description": "Full applicability date for all platforms", "source_url": null }
      ],
      "litigations": [],
