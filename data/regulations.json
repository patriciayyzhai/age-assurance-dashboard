    {
      "id": "UK-OSA-2023",
      "name": "Online Safety Act 2023",
      "jurisdiction_id": "GB",
      "summary": "UK's comprehensive online safety legislation requiring platforms to protect children from harmful content. Includes age assurance requirements for services likely to be accessed by children. Ofcom is the regulator.",
      "status": "enforced",
      "service_type_ids": ["social_media", "streaming", "adult_content", "pornography"],
      "year": 2023,
      "source_url": "https://www.legislation.gov.uk/ukpga/2023/50/contents",
      "tags": ["online_safety", "child_protection", "age_assurance", "ofcom"],
      "obligations": [
        {
          "id": "UK-OSA-2023-OBL-1",
          "regulation_id": "UK-OSA-2023",
          "type": "age_verification",
          "description": "Services likely to be accessed by children must use highly effective age assurance to prevent children from encountering harmful content",
          "threshold_age": 18,
          "applies_to_service_types": ["social_media", "streaming", "adult_content", "pornography"]
        },
        {
          "id": "UK-OSA-2023-OBL-2",
          "regulation_id": "UK-OSA-2023",
          "type": "age_estimation",
          "description": "Platforms must use age estimation or verification technologies to determine user age",
          "threshold_age": 13,
          "applies_to_service_types": ["social_media", "streaming"]
        },
        {
          "id": "UK-OSA-2023-OBL-3",
          "regulation_id": "UK-OSA-2023",
          "type": "content_moderation",
          "description": "Platforms must remove illegal content and content harmful to children",
          "threshold_age": null,
          "applies_to_service_types": ["social_media", "streaming"]
        },
        {
          "id": "UK-OSA-2023-OBL-4",
          "regulation_id": "UK-OSA-2023",
          "type": "reporting_obligation",
          "description": "Platforms must conduct and publish annual children's safety risk assessments",
          "threshold_age": null,
          "applies_to_service_types": ["social_media", "streaming", "adult_content", "pornography"]
        },
        {
          "id": "UK-OSA-2023-OBL-5",
          "regulation_id": "UK-OSA-2023",
          "type": "design_restrictions",
          "description": "Platforms must implement safety-by-design features for child users",
          "threshold_age": null,
          "applies_to_service_types": ["social_media"]
        }
      ],
      "milestones": [
        { "id": "UK-OSA-2023-MS-1", "regulation_id": "UK-OSA-2023", "type": "introduced", "date": "2019-04-08", "description": "Online Harms White Paper published", "source_url": null },
        { "id": "UK-OSA-2023-MS-2", "regulation_id": "UK-OSA-2023", "type": "introduced", "date": "2022-03-17", "description": "Online Safety Bill introduced to Parliament", "source_url": null },
        { "id": "UK-OSA-2023-MS-3", "regulation_id": "UK-OSA-2023", "type": "passed", "date": "2023-09-19", "description": "Passed Parliament", "source_url": null },
        { "id": "UK-OSA-2023-MS-4", "regulation_id": "UK-OSA-2023", "type": "signed", "date": "2023-10-26", "description": "Received Royal Assent", "source_url": null },
        { "id": "UK-OSA-2023-MS-5", "regulation_id": "UK-OSA-2023", "type": "effective", "date": "2024-03-16", "description": "First wave of duties came into force", "source_url": null },
        { "id": "UK-OSA-2023-MS-6", "regulation_id": "UK-OSA-2023", "type": "enforced", "date": "2025-01-16", "description": "Ofcom begins enforcement of children's safety duties", "source_url": null }
